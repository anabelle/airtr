{
  "name": "acars",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source decentralized airline management game on Nostr",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @acars/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test -- --run",
    "verify:contracts": "pnpm -r build && pnpm -r typecheck",
    "verify:boundaries": "pnpm -r lint",
    "verify:determinism": "pnpm --filter @acars/core test -- --run",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,cjs,mjs,json,css,scss,html}": [
      "bash -lc 'for f in \"$@\"; do if [ \"$f\" != \"packages/data/src/airports.ts\" ]; then printf \"%s\\n\" \"$f\"; fi; done | xargs -r biome format --write' --"
    ],
    "**/*.{md,mdx,yml,yaml}": [
      "prettier --write"
    ],
    "**/*.{ts,tsx,js,jsx,cjs,mjs}": [
      "bash -lc 'for f in \"$@\"; do if [ \"$f\" != \"packages/data/src/airports.ts\" ]; then printf \"%s\\n\" \"$f\"; fi; done | xargs -r eslint' --"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
