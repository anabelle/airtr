{
  "name": "airtr",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source decentralized airline management game on Nostr",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @airtr/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test -- --run",
    "verify:contracts": "echo 'TODO: contract verification'",
    "verify:boundaries": "echo 'TODO: boundary verification'",
    "verify:determinism": "echo 'TODO: determinism verification'",
    "clean": "pnpm -r clean && rm -rf node_modules"
  }
}
